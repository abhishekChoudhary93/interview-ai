# Copy to `.env.local` and adjust.

# --- Local mock (no Base44 account or network for API) ---
# Interview data is in-memory and resets on full page refresh.
VITE_USE_MOCK_BASE44=true

# --- Real Base44 backend (set to false or remove the line above) ---
# VITE_USE_MOCK_BASE44=false
# VITE_BASE44_APP_ID=your_app_id
# VITE_BASE44_APP_BASE_URL=https://your-app.base44.app
