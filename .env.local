# Local Docker stack — used with: docker compose --env-file .env.local -f docker-compose.yml ...
# Values here override/substitute variables referenced in docker-compose.yml.

JWT_SECRET=dev-jwt-secret-change-in-production

# OpenRouter — required for the orchestrated interviewer flow.
# Without it, only legacy non-orchestrated code paths fall back to a deterministic mock.
# DO NOT commit a real key — replace this placeholder in your local checkout or export it in your shell.
OPENROUTER_API_KEY=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

# Per-tier model selection. Edit any line to change which OpenRouter model is used.
# Confirm what the container ends up with in `npm run logs` at startup:
#   "[llm] OpenRouter ENABLED — conversational=..., opening=..., eval=..., debrief=..."
# NOTE: docker compose --env-file does NOT support inline comments after values, so
# comments live on their own lines.

# Both the Planner and the Executor run on DeepSeek V3 — strong instruction
# following at ~$0.05/interview total. Single-line revert path if a fixture
# trace shows a regression: swap any line back to anthropic/claude-3.5-sonnet
# (requires Anthropic credits on OpenRouter).
#
# Streaming interviewer voice (the candidate hears this one).
OPENROUTER_CONVERSATIONAL_MODEL=deepseek/deepseek-chat
# Opening line at session start (now deterministic — no LLM call — but kept
# wired for fallback paths).
OPENROUTER_OPENING_MODEL=deepseek/deepseek-chat
# Background per-turn rubric grading (the Planner — biggest decision-maker).
OPENROUTER_EVAL_MODEL=deepseek/deepseek-chat
# Final structured report.
OPENROUTER_DEBRIEF_MODEL=deepseek/deepseek-chat
# Fallback for any tier above (and the only knob the legacy code paths read).
OPENROUTER_MODEL=deepseek/deepseek-chat

# Pin OpenRouter provider routing — required for DeepSeek context caching to land.
# Only DeepSeek's official infra supports caching; other deepseek/* hosters
# (Fireworks / Together / Novita / DeepInfra / etc.) do not. Comma-separated
# priority list; allow_fallbacks=false on the wire.
OPENROUTER_PROVIDERS=DeepSeek

DEMO_USER_EMAIL=demo@interview-ai.local
DEMO_USER_PASSWORD=demo123456
DEMO_USER_NAME=Demo User

# Per-turn Executor + Planner debug trace (local-only).
# Backend writes session_state.debug_trace[] when set; frontend page /interview/<id>/debug renders it.
INTERVIEW_DEBUG_TRACE=1
VITE_DEBUG_TRACE=1
