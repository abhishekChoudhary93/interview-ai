# Production stack — used with: docker compose --env-file .env.production -f docker-compose.prod.yml ...
# Set MONGODB_URI, JWT_SECRET, and origins to your real deployment values before going live.

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/interview_ai
JWT_SECRET=CHANGE_ME_USE_CRYPTO_RANDOM_SECRET_AT_LEAST_24_CHARS_LONG
FRONTEND_ORIGIN=https://app.example.com
VITE_API_URL=https://api.example.com
BACKEND_PORT=3001
FRONTEND_HTTP_PORT=8080
