# Production stack — used with: docker compose --env-file .env.production -f docker-compose.prod.yml ...
# Set MONGODB_URI, JWT_SECRET, JWT_REFRESH_SECRET, FRONTEND_ORIGIN, and OPENROUTER_API_KEY before going live.

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/interview_ai
JWT_SECRET=CHANGE_ME_USE_CRYPTO_RANDOM_SECRET_AT_LEAST_24_CHARS_LONG
JWT_REFRESH_SECRET=CHANGE_ME_USE_A_DIFFERENT_LONG_RANDOM_SECRET_AT_LEAST_24_CHARS
FRONTEND_ORIGIN=https://app.example.com

# OpenRouter — required.
OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Per-tier model overrides. Both Planner and Executor on DeepSeek V3
# (~$0.05/interview total). Single-line revert: swap any line back to
# anthropic/claude-3.5-sonnet if a fixture trace shows a regression.
OPENROUTER_CONVERSATIONAL_MODEL=deepseek/deepseek-chat
OPENROUTER_OPENING_MODEL=deepseek/deepseek-chat
OPENROUTER_EVAL_MODEL=deepseek/deepseek-chat
OPENROUTER_DEBRIEF_MODEL=deepseek/deepseek-chat
# Fallback for any tier above without an explicit override.
OPENROUTER_MODEL=deepseek/deepseek-chat

VITE_API_URL=https://api.example.com
BACKEND_PORT=3001
FRONTEND_HTTP_PORT=8080
